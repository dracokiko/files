{
  "version": 2,
  "buildCommand": "cd aulaiq && npm install && npm run build",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "aulaiq/dist/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
